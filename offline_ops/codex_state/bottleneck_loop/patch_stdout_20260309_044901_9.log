+            duplicateBuyPrice = price
+        end
+    end
+end
+assert(duplicateItemId ~= nil, 'expected one affordable non-stackable npc buy candidate')
+local buyStartMesos = buyPlayer.mesos
+local buyStartTxCount = #runtime.economySystem.transactions
