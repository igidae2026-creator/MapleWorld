+local buyPlayer = runtime.players.p1
+local duplicateItemId = runtime.starterWeaponId
+local buyStartMesos = buyPlayer.mesos
+local buyStartTxCount = #runtime.economySystem.transactions
+local buyStartSeq = runtime.eventSeq
+local buyStartInventoryCount = buyPlayer.inventory[duplicateItemId] and #buyPlayer.inventory[duplicateItemId] or 0
+local duplicateBuyPrice = assert(runtime.economySystem:quoteNpcBuy(duplicateItemId, 1))
+
+local firstBuy = runtime:buyFromNpc({
+    playerId = 'p1',
+    itemId = duplicateItemId,
+    quantity = 1,
+    npcId = 'npc',
