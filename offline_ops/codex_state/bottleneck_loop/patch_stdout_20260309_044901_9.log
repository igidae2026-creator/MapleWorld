+    local price = runtime.economySystem:quoteNpcBuy(candidateItemId, 1)
+    if item.stackable == false and price and price > 0 and price <= buyPlayer.mesos then
+        if duplicateBuyPrice == nil
+            or price < duplicateBuyPrice
