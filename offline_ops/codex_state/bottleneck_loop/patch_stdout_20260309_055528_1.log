from __future__ import annotations


def _clamp(value: int, floor: int = 60, ceiling: int = 95) -> int:
    return max(floor, min(ceiling, int(value)))


def _range_string(center: int) -> str:
    center = _clamp(center)
    low = _clamp(center - 1)
    high = _clamp(center + 2)
    return f"{low}~{high}"


