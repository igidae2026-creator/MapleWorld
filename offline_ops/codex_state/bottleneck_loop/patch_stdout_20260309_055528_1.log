# identify relevant formulas from simulate_variant? We'll inline using helpers

def closeness(value,target,tol):
    return ap.closeness(value,target,tol)

def avg(xs):
    return ap.average(xs)

boss_rows=list(csv.DictReader((root/'data/balance/bosses/boss_rewards.csv').open()))
reward_per_member_mean=ap.average([float(r['reward_currency'])/max(1.0,float(r['party_size'])) for r in boss_rows])
double_limit_share=ap.share(boss_rows, lambda row: float(row['weekly_limit']) >= 2.0)
boss_reward_distortion=ap.rounded(avg([
    closeness(params['boss_reward_cadence'], 0.63, 0.08),
