        boss_reward_distortion,
    ]))
    print(name, 'sink_weight_mean',round(sink_weight_mean,4),'boss_mean',round(boss_entry_sink_mean,4),'meso_hour',meso_hour_pressure,'reward_sink',reward_sink_coherence)
