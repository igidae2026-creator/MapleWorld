import csv,re,collections
path='data/balance/drops/drop_table.csv'
pat=re.compile(r'tier(\\d+)_')
armor=('overall','glove','shoe')
counts=collections.Counter()
rows=collections.defaultdict(list)
with open(path,newline='') as f:
    for row in csv.DictReader(f):
        item=row['item_id']
        if row['rarity_band'] not in ('common','uncommon'):
            continue
        if not any(a in item for a in armor):
            continue
        m=pat.search(item)
        if not m:
            continue
        tier=int(m.group(1))
        counts[tier]+=1
        rows[tier].append((row['monster_id'],item,row['rarity_band'],row['drop_profile'],row['drop_rate']))
for tier,count in counts.most_common(12):
    print('tier',tier,'count',count)
    sample=rows[tier][:6]
    for r in sample:
        print(' ',r)
