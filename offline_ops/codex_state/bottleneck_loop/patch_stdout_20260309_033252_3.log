exec
/bin/bash -lc "python3 - <<'PY'
import csv,re
from decimal import Decimal, ROUND_HALF_UP
path='data/balance/drops/drop_table.csv'
pat=re.compile(r'tier(\\d+)_')
armor=('overall','glove','shoe')
common_factor=Decimal('0.70')
uncommon_factor=Decimal('0.78')
rows=[]
with open(path,newline='') as f:
    reader=csv.DictReader(f)
    fieldnames=reader.fieldnames
    for row in reader:
        item=row['item_id']
        if row['rarity_band'] in ('common','uncommon') and any(a in item for a in armor):
            m=pat.search(item)
            if m and int(m.group(1)) in (9,10,21,22):
                rate=Decimal(row['drop_rate'])
                factor=common_factor if row['rarity_band']=='common' else uncommon_factor
                row['drop_rate']=str((rate*factor).quantize(Decimal('0.0001'), rounding=ROUND_HALF_UP))
        rows.append(row)
with open(path,'w',newline='') as f:
    writer=csv.DictWriter(f,fieldnames=fieldnames)
    writer.writeheader()
    writer.writerows(rows)
