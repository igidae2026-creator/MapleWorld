package.path = package.path .. ';./?.lua;../?.lua'

local function readCsv(path)
    local handle = assert(io.open(path, 'r'))
    local rows = {}
    local headers = nil
    for line in handle:lines() do
        local cols = {}
        for value in string.gmatch(line, '([^,]+)') do
            cols[#cols + 1] = value
        end
        if not headers then
            headers = cols
        else
            local row = {}
            for idx, header in ipairs(headers) do
                row[header] = cols[idx]
            end
            rows[#rows + 1] = row
        end
