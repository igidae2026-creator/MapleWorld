# Wave 1 MapleWorld development environment placeholders.
# Copy to .env only for local development values.
# Do not store secrets here. Secrets and production settings are deferred to later waves.

# Enables development-oriented bootstrap behavior in scripts/env/dev_env.sh.
MAPLELAND_DEV_MODE=1

# Signals that local development is expected to run inside WSL, when applicable.
MAPLELAND_WSL_EXPECTED=1

# Local-only Node environment hint for future bootstrap scripts.
MAPLELAND_NODE_ENV=development

# Placeholder port for future local tooling; adjust if your local stack needs a different port.
MAPLELAND_LOCAL_PORT=3000

# Placeholder Codex runner profile for local scaffolding only.
CODEX_RUNNER_PROFILE=local

# Placeholder bootstrap phase marker so future scripts can branch conservatively by wave.
CODEX_BOOTSTRAP_MODE=wave1
